# Copy to .env.production.local on the production server.
# This file is used by docker compose variable substitution:
# docker compose --env-file .env.production.local -f docker-compose.prod.yml up -d

POSTGRES_DB=ahso_crm
POSTGRES_USER=ahso
POSTGRES_PASSWORD=replace-with-a-long-random-password

BACKEND_IMAGE=ghcr.io/ahsocode/ahso-crm-backend:latest
FRONTEND_IMAGE=ghcr.io/ahsocode/ahso-crm-frontend:latest

# Bind to loopback when a reverse proxy terminates TLS on the same host.
BACKEND_BIND=127.0.0.1:3001
FRONTEND_BIND=127.0.0.1:3000

# Keep local uploaded PDFs/logos/survey files outside the container layer.
UPLOADS_DIR=./backend/uploads
