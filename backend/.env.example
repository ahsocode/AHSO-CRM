DATABASE_URL="postgresql://ahso:ahso_dev_password@localhost:5432/ahso_crm?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="ahso-dev-secret-change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_RESET_SECRET="ahso-dev-reset-secret-change-me"
JWT_RESET_EXPIRES_IN="15m"
UPLOAD_DIR="./uploads"
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
LOG_LEVEL="debug"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AHSO CRM <noreply@ahso.vn>"
TWILIO_SID=""
TWILIO_TOKEN=""
TWILIO_FROM=""
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1

# Comma-separated list of allowed origins for CORS
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Enable Swagger in production (default: only enabled when NODE_ENV !== production)
SWAGGER_ENABLED="true"

# Rate limiting (requests per window)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
