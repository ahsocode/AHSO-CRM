# Copy to backend/.env.production.local on the production server.
# Do not commit real production secrets.

PORT=3001
NODE_ENV=production
UPLOAD_DIR="./uploads"
LOG_LEVEL="info"

JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_RESET_SECRET="replace-with-a-different-32-random-character-secret"
JWT_RESET_EXPIRES_IN="15m"

FRONTEND_URL="https://crm.example.com"
CORS_ORIGIN="https://crm.example.com"
SWAGGER_ENABLED="false"

THROTTLE_TTL=60
THROTTLE_LIMIT=100

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AHSO CRM <noreply@example.com>"

TWILIO_SID=""
TWILIO_TOKEN=""
TWILIO_FROM=""

VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""

SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1
