# Copy to backend/.env.production.local on the production server.
# Do not commit real production secrets.

PORT=3001
NODE_ENV=production
UPLOAD_DIR="./uploads"
LOG_LEVEL="info"

JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-32-random-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_RESET_SECRET="replace-with-a-different-32-random-character-secret"
JWT_RESET_EXPIRES_IN="15m"

# BẮTBUỘC: 32 ký tự bất kỳ hoặc 64 ký tự hex — dùng để mã hoá mật khẩu email IMAP/SMTP.
# Tạo: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-hex-chars-from-openssl-rand-hex-32"

FRONTEND_URL="https://crm.example.com"
CORS_ORIGIN="https://crm.example.com"
SWAGGER_ENABLED="false"

THROTTLE_TTL=60
THROTTLE_LIMIT=100

AI_PROVIDER="anthropic"
AI_AUTH_MODE="api_key"
AI_REQUEST_TIMEOUT_MS=30000
AI_OAUTH_ACCESS_TOKEN=""
AI_OAUTH_REDIRECT_URI_ALLOWLIST="https://crm.example.com/admin/ai-providers/callback"
AHSO_IMAP_HOST="mail90168.maychuemail.com"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
ANTHROPIC_OAUTH_CLIENT_ID=""
ANTHROPIC_OAUTH_CLIENT_SECRET=""
ANTHROPIC_OAUTH_AUTH_URL=""
ANTHROPIC_OAUTH_TOKEN_URL=""
ANTHROPIC_OAUTH_SCOPES=""
OPENAI_API_KEY=""
OPENAI_OAUTH_ACCESS_TOKEN=""
OPENAI_OAUTH_CLIENT_ID=""
OPENAI_OAUTH_CLIENT_SECRET=""
OPENAI_OAUTH_AUTH_URL=""
OPENAI_OAUTH_TOKEN_URL=""
OPENAI_OAUTH_SCOPES=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com"
GEMINI_API_KEY=""
GEMINI_OAUTH_ACCESS_TOKEN=""
GEMINI_OAUTH_CLIENT_ID=""
GEMINI_OAUTH_CLIENT_SECRET=""
GEMINI_OAUTH_AUTH_URL="https://accounts.google.com/o/oauth2/v2/auth"
GEMINI_OAUTH_TOKEN_URL="https://oauth2.googleapis.com/token"
GEMINI_OAUTH_SCOPES="https://www.googleapis.com/auth/generative-language.retriever"
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"

SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AHSO CRM <noreply@example.com>"

TWILIO_SID=""
TWILIO_TOKEN=""
TWILIO_FROM=""

VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""

SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1

# Backup / Restore — chạy `rclone listremotes` trên VPS để lấy tên remote đúng.
# Ví dụ: "gdrive:AHSO-CRM-Backups" hoặc "AHSO-CRM-Backup:AHSO-CRM-Backups"
RCLONE_REMOTE="AHSO-CRM-Backup:AHSO-CRM-Backups"
# Tên container Postgres (xem `docker ps` trên VPS)
POSTGRES_CONTAINER="ahso-crm-postgres-1"

# AI Provider — chọn một trong: anthropic | openai | gemini
# Nếu dùng api_key: điền *_API_KEY tương ứng.
# Nếu dùng oauth: điền *_OAUTH_* tương ứng.
AI_PROVIDER="anthropic"
AI_AUTH_MODE="api_key"
AI_REQUEST_TIMEOUT_MS=30000
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
# OAuth (bỏ trống nếu dùng api_key)
ANTHROPIC_OAUTH_CLIENT_ID=""
ANTHROPIC_OAUTH_CLIENT_SECRET=""
ANTHROPIC_OAUTH_AUTH_URL=""
ANTHROPIC_OAUTH_TOKEN_URL=""
ANTHROPIC_OAUTH_SCOPES=""
AI_OAUTH_ACCESS_TOKEN=""
AI_OAUTH_REDIRECT_URI_ALLOWLIST="https://crm.example.com/admin/ai-providers/callback"
