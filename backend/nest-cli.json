{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "email/templates/**/*", "outDir": "./dist" },
      { "include": "documents/templates/**/*", "outDir": "./dist" },
      { "include": "documents/i18n/**/*", "outDir": "./dist" }
    ],
    "watchAssets": true
  }
}
