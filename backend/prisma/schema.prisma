generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  name              String
  password          String
  role              UserRole   @relation(fields: [roleId], references: [id])
  roleId            String
  avatarUrl         String?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  sessions          UserSession[]
  assignedCustomers Customer[] @relation("AssignedTo")
  createdQuotes     Quote[]
  activities        Activity[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  reportTemplates   ReportTemplate[]
  documents         Document[]
  businessDocuments BusinessDocument[] @relation("BusinessDocumentCreatedBy")
  surveysCreated    Survey[]           @relation("SurveyCreatedBy")
  surveyMedia        SurveyMedia[]      @relation("SurveyMediaUploadedBy")
  surveyNotes        SurveyNote[]       @relation("SurveyNoteCreatedBy")
  projectHandoversCreated ProjectHandover[] @relation("ProjectHandoverCreatedBy")
  projectHandoversFrom    ProjectHandover[] @relation("ProjectHandoverFromUser")
  projectHandoversTo      ProjectHandover[] @relation("ProjectHandoverToUser")
  documentTemplateVariantsCreated  DocumentTemplateVariant[] @relation("DocumentTemplateCreatedBy")
  documentTemplateVariantsApproved DocumentTemplateVariant[] @relation("DocumentTemplateApprovedBy")
  emailAccount     EmailAccount?
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserRole {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false) // ADMIN, MANAGER, STAFF are system roles
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([name])
}

model Permission {
  id         String     @id @default(cuid())
  resource   String     // "activities", "customers", "projects", "quotes", "contracts", "payments", "settings", "users"
  action     String     // "view", "create", "edit", "delete"
  roles      UserRole[]
  createdAt  DateTime   @default(now())

  @@unique([resource, action])
  @@index([resource])
}

model Setting {
  key         String   @id @unique
  value       String   // JSON-stringified values
  description String?
  updatedAt   DateTime @updatedAt
}

model Logo {
  id         String   @id @default(cuid())
  url        String   // URL to /uploads or CDN
  filename   String
  uploadedAt DateTime @default(now())

  @@index([uploadedAt])
}

model Customer {
  id           String         @id @default(cuid())
  name         String
  shortName    String?
  code         String?        @unique
  language     String         @default("vi")
  taxCode      String?        @unique
  industry     String?
  address      String?
  website      String?
  phone        String?
  email        String?
  source       String?
  notes        String?
  status       CustomerStatus @default(LEAD)
  isVip        Boolean        @default(false)
  deletedAt    DateTime?
  assignedTo   User           @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  contacts     Contact[]
  projects     Project[]
  activities   Activity[]
  documents    Document[]
  businessDocuments BusinessDocument[]
  surveys      Survey[]
  emails       EmailMessage[]

  @@index([deletedAt])
  @@index([assignedToId, deletedAt])
  @@index([status, deletedAt])
}

model EmailAccount {
  id         String         @id @default(cuid())
  userId     String         @unique
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  imapHost   String         @default("mail.ahso.vn")
  imapPort   Int            @default(993)
  imapSecure Boolean        @default(true)
  smtpHost   String         @default("mail.ahso.vn")
  smtpPort   Int            @default(587)
  password   String
  lastSyncAt DateTime?
  isActive   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  messages   EmailMessage[]
}

model EmailMessage {
  id             String            @id @default(cuid())
  accountId      String
  account        EmailAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  uid            Int
  folder         String
  messageId      String?
  inReplyTo      String?
  fromName       String?
  fromEmail      String
  toAddresses    Json
  ccAddresses    Json              @default("[]")
  bccAddresses   Json              @default("[]")
  subject        String?
  bodyText       String?
  bodyHtml       String?
  snippet        String?
  isRead         Boolean           @default(false)
  isStarred      Boolean           @default(false)
  isDraft        Boolean           @default(false)
  hasAttachments Boolean           @default(false)
  size           Int               @default(0)
  receivedAt     DateTime
  createdAt      DateTime          @default(now())
  attachments    EmailAttachment[]
  customerId     String?
  customer       Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([accountId, uid, folder])
  @@index([accountId, folder, receivedAt(sort: Desc)])
  @@index([customerId])
  @@index([fromEmail])
}

model EmailAttachment {
  id        String       @id @default(cuid())
  messageId String
  message   EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  filePath  String?
  cid       String?
}

enum CustomerStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
}

model Contact {
  id         String    @id @default(cuid())
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean   @default(false)
  notes      String?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
}

model Project {
  id              String        @id @default(cuid())
  code            String        @unique @default(cuid())
  name            String
  description     String?
  status          ProjectStatus @default(SURVEY)
  priority        Priority      @default(NORMAL)
  estimatedValue  Decimal?      @db.Decimal(15, 0)
  startDate       DateTime?
  expectedEndDate DateTime?
  notes           String?
  deletedAt       DateTime?
  customer        Customer      @relation(fields: [customerId], references: [id])
  customerId      String
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  quotes          Quote[]
  contract        Contract?
  activities      Activity[]
  milestones      Milestone[]
  businessDocuments BusinessDocument[]
  surveys         Survey[]
  handovers       ProjectHandover[]

  @@index([customerId, deletedAt])
  @@index([status, deletedAt])
}

enum ProjectStatus {
  SURVEY
  QUOTING
  NEGOTIATING
  WON
  LOST
  DELIVERING
  COMPLETED
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

model Quote {
  id            String      @id @default(cuid())
  quoteNo       String      @unique
  version       Int         @default(1)
  status        QuoteStatus @default(DRAFT)
  validUntil    DateTime?
  subtotal      Decimal     @default(0) @db.Decimal(15, 0)
  taxRate       Decimal     @default(10) @db.Decimal(5, 2)
  taxAmount     Decimal     @default(0) @db.Decimal(15, 0)
  total         Decimal     @default(0) @db.Decimal(15, 0)
  terms         String?
  deliveryTerms String?
  internalNote  String?
  sentAt        DateTime?
  acceptedAt    DateTime?
  project       Project     @relation(fields: [projectId], references: [id])
  projectId     String
  createdBy     User        @relation(fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  items         QuoteItem[]
  businessDocuments BusinessDocument[]

  @@index([projectId, deletedAt])
  @@index([status, deletedAt])
  @@index([createdById, deletedAt])
}

model QuoteItem {
  id          String   @id @default(cuid())
  order       Int
  name        String
  description String?
  unit        String?
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 0)
  total       Decimal  @db.Decimal(15, 0)
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String

  @@index([quoteId, order])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Contract {
  id         String         @id @default(cuid())
  contractNo String         @unique
  signDate   DateTime?
  startDate  DateTime?
  endDate    DateTime?
  value      Decimal        @db.Decimal(15, 0)
  status     ContractStatus @default(ACTIVE)
  fileUrl    String?
  notes      String?
  project    Project        @relation(fields: [projectId], references: [id])
  projectId  String         @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  milestones Milestone[]
  payments   Payment[]
  businessDocuments BusinessDocument[]

  @@index([projectId, deletedAt])
  @@index([status, deletedAt])
}

enum ContractStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
}

model Milestone {
  id            String          @id @default(cuid())
  name          String
  description   String?
  dueDate       DateTime?
  completedAt   DateTime?
  status        MilestoneStatus @default(PENDING)
  paymentAmount Decimal?        @db.Decimal(15, 0)
  notes         String?
  project       Project         @relation(fields: [projectId], references: [id])
  projectId     String
  contract      Contract?       @relation(fields: [contractId], references: [id])
  contractId    String?
  createdAt     DateTime        @default(now())
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
  ACCEPTED
}

model Payment {
  id         String   @id @default(cuid())
  amount     Decimal  @db.Decimal(15, 0)
  paidAt     DateTime
  method     String?
  reference  String?
  notes      String?
  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String
  businessDocuments BusinessDocument[]
  createdAt  DateTime @default(now())
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  title         String
  content       String?
  scheduledAt   DateTime?
  doneAt        DateTime?
  isCompleted   Boolean      @default(false)
  attachmentUrl String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  customerId    String?
  project       Project?     @relation(fields: [projectId], references: [id])
  projectId     String?
  user          User         @relation(fields: [userId], references: [id])
  userId        String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?    // soft delete
}

model Survey {
  id                   String        @id @default(cuid())
  title                String
  surveyedAt           DateTime?
  location             String?
  customerParticipants String?
  objectives           String?
  summary              String?
  nextStep             String?
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId           String
  project              Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId            String?
  createdBy            User          @relation("SurveyCreatedBy", fields: [createdById], references: [id])
  createdById          String
  media                SurveyMedia[]
  notes                SurveyNote[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([projectId, surveyedAt])
  @@index([customerId, surveyedAt])
  @@index([createdById, createdAt])
}

model SurveyMedia {
  id           String          @id @default(cuid())
  survey       Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  surveyId     String
  kind         SurveyMediaKind
  url          String
  filename     String
  mimeType     String
  size         Int
  caption      String?
  area         String?
  isImportant  Boolean         @default(false)
  uploadedBy   User            @relation("SurveyMediaUploadedBy", fields: [uploadedById], references: [id])
  uploadedById String
  createdAt    DateTime        @default(now())

  @@index([surveyId, createdAt])
  @@index([uploadedById, createdAt])
}

model SurveyNote {
  id          String         @id @default(cuid())
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  surveyId    String
  type        SurveyNoteType @default(GENERAL)
  content     String
  isImportant Boolean        @default(false)
  createdBy   User           @relation("SurveyNoteCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([surveyId, createdAt])
  @@index([createdById, createdAt])
}

enum SurveyMediaKind {
  IMAGE
  VIDEO
  FILE
}

enum SurveyNoteType {
  GENERAL
  TECHNICAL_REQUIREMENT
  COMMERCIAL_REQUIREMENT
  SITE_CONSTRAINT
  RISK
  DECISION
  OPEN_QUESTION
}

model BusinessDocument {
  id                  String                 @id @default(cuid())
  type                BusinessDocumentType
  source              BusinessDocumentSource
  status              BusinessDocumentStatus @default(RECEIVED)
  title               String
  documentNo          String?
  documentDate        DateTime?
  fileUrl             String?
  filename            String?
  mimeType            String?
  size                Int?
  notes               String?
  customer            Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId          String?
  project             Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId           String?
  quote               Quote?                 @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  quoteId             String?
  contract            Contract?              @relation(fields: [contractId], references: [id], onDelete: SetNull)
  contractId          String?
  payment             Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  paymentId           String?
  generatedDocument   Document?              @relation(fields: [generatedDocumentId], references: [id], onDelete: SetNull)
  generatedDocumentId String?
  parent              BusinessDocument?      @relation("BusinessDocumentLineage", fields: [parentId], references: [id], onDelete: SetNull)
  parentId            String?
  children            BusinessDocument[]     @relation("BusinessDocumentLineage")
  createdBy           User                   @relation("BusinessDocumentCreatedBy", fields: [createdById], references: [id])
  createdById         String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([projectId, type, createdAt])
  @@index([customerId, createdAt])
  @@index([quoteId])
  @@index([contractId])
  @@index([paymentId])
  @@index([parentId])
  @@index([createdById, createdAt])
}

enum BusinessDocumentType {
  RFQ
  CUSTOMER_PO
  QUOTATION
  SIGNED_QUOTATION
  PROPOSAL
  CONTRACT
  SIGNED_CONTRACT
  CONTRACT_ADDENDUM
  NDA
  DELIVERY_NOTE
  DOC_HANDOVER
  INSTALLATION_REPORT
  ACCEPTANCE_REPORT
  PARTIAL_ACCEPTANCE
  WARRANTY_CERT
  MAINTENANCE_RECORD
  PAYMENT_REQUEST
  PAYMENT_RECEIPT
  INVOICE
  AR_RECONCILIATION
  OTHER
}

enum BusinessDocumentSource {
  GENERATED
  UPLOADED
  RECEIVED
  SIGNED_UPLOAD
}

enum BusinessDocumentStatus {
  DRAFT
  ISSUED
  RECEIVED
  SIGNED
  ACCEPTED
  REJECTED
  SUPERSEDED
  CANCELLED
  ARCHIVED
}

model ProjectHandover {
  id                   String   @id @default(cuid())
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  summary              String?
  customerRequirements String?
  risks                String?
  decisions            String?
  openTasks            String?
  importantDocumentIds String[]
  fromUser             User?    @relation("ProjectHandoverFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  fromUserId           String?
  toUser               User?    @relation("ProjectHandoverToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  toUserId             String?
  createdBy            User     @relation("ProjectHandoverCreatedBy", fields: [createdById], references: [id])
  createdById          String
  createdAt            DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([createdById, createdAt])
}

model Webhook {
  id         String       @id @default(cuid())
  url        String
  events     String[]
  secret     String
  isActive   Boolean      @default(true)
  createdBy  String
  createdAt  DateTime     @default(now())
  lastFired  DateTime?
  failCount  Int          @default(0)
  logs       WebhookLog[]

  @@index([createdBy, createdAt])
  @@index([isActive])
}

model WebhookLog {
  id         String    @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  response   String?
  statusCode Int?
  firedAt    DateTime  @default(now())
  webhook    Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, firedAt])
  @@index([event, firedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  changes    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CustomField {
  id        String   @id @default(cuid())
  resource  String
  name      String
  label     String
  type      String
  options   Json?
  required  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  values    CustomFieldValue[]

  @@unique([resource, name])
  @@index([resource, order])
}

model CustomFieldValue {
  id         String      @id @default(cuid())
  fieldId     String
  resourceId  String
  value       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  field       CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, resourceId])
  @@index([resourceId])
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdById String
  resource    String
  config      Json
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById, createdAt])
  @@index([resource, isShared])
}

model DocumentTemplateVariant {
  id              String                 @id @default(cuid())
  type            DocumentType
  name            String
  status          DocumentTemplateStatus @default(DRAFT)
  isActive        Boolean                @default(false)
  layoutJson      Json
  version         Int                    @default(1)
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  basedOnVariantId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdBy       User                   @relation("DocumentTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy      User?                  @relation("DocumentTemplateApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  basedOnVariant  DocumentTemplateVariant? @relation("DocumentTemplateVariantFork", fields: [basedOnVariantId], references: [id], onDelete: SetNull)
  derivedVariants DocumentTemplateVariant[] @relation("DocumentTemplateVariantFork")

  @@index([type, status, createdAt])
  @@index([type, isActive])
  @@index([createdById, createdAt])
}

enum DocumentTemplateStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ARCHIVED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SURVEY
  DEMO
  NOTE
  FOLLOWUP
}

model Document {
  id          String       @id @default(cuid())
  type        DocumentType
  number      String       @unique
  version     Int          @default(1)
  language    String       @default("vi")
  entityType  String
  entityId    String
  customerId  String?
  pdfPath     String?
  renderedAt  DateTime?
  createdAt   DateTime     @default(now())
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  businessDocuments BusinessDocument[]

  @@index([entityType, entityId])
  @@index([customerId])
  @@index([type, createdAt])
}

enum DocumentType {
  QUOTATION
  PROPOSAL
  SURVEY_REPORT
  CONTRACT
  CONTRACT_ADDENDUM
  NDA
  DELIVERY_NOTE
  DOC_HANDOVER
  INSTALLATION_REPORT
  ACCEPTANCE_REPORT
  PARTIAL_ACCEPTANCE
  WARRANTY_CERT
  MAINTENANCE_RECORD
  PAYMENT_REQUEST
  PAYMENT_RECEIPT
  AR_RECONCILIATION
}
