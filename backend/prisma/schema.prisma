generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                               String                    @id @default(cuid())
  email                            String                    @unique
  name                             String
  password                         String
  role                             UserRole                  @relation(fields: [roleId], references: [id])
  roleId                           String
  avatarUrl                        String?
  isActive                         Boolean                   @default(true)
  createdAt                        DateTime                  @default(now())
  updatedAt                        DateTime                  @updatedAt
  sessions                         UserSession[]
  assignedCustomers                Customer[]                @relation("AssignedTo")
  createdQuotes                    Quote[]
  activities                       Activity[]
  notifications                    Notification[]
  pushSubscriptions                PushSubscription[]
  reportTemplates                  ReportTemplate[]
  documents                        Document[]
  businessDocuments                BusinessDocument[]        @relation("BusinessDocumentCreatedBy")
  surveysCreated                   Survey[]                  @relation("SurveyCreatedBy")
  surveyMedia                      SurveyMedia[]             @relation("SurveyMediaUploadedBy")
  surveyNotes                      SurveyNote[]              @relation("SurveyNoteCreatedBy")
  projectHandoversCreated          ProjectHandover[]         @relation("ProjectHandoverCreatedBy")
  projectHandoversFrom             ProjectHandover[]         @relation("ProjectHandoverFromUser")
  projectHandoversTo               ProjectHandover[]         @relation("ProjectHandoverToUser")
  documentTemplateVariantsCreated  DocumentTemplateVariant[] @relation("DocumentTemplateCreatedBy")
  documentTemplateVariantsApproved DocumentTemplateVariant[] @relation("DocumentTemplateApprovedBy")
  emailAccount                     EmailAccount?
  managedWarehouses                Warehouse[]               @relation("WarehouseManager")
  createdReceipts                  StockReceipt[]            @relation("ReceiptCreatedBy")
  createdIssues                    StockIssue[]              @relation("IssueCreatedBy")
  createdTransfers                 StockTransfer[]           @relation("TransferCreatedBy")
  createdCounts                    StockCount[]              @relation("CountCreatedBy")
  aiUsageLogs                      AiUsageLog[]
  agentsCreated                    Agent[]                   @relation("AgentCreatedBy")
  agentRuns                        AgentRun[]
  webhooksCreated                  Webhook[]                 @relation("WebhookCreatedBy")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String
  tokenHash    String?  @unique
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserRole {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false) // ADMIN, MANAGER, STAFF are system roles
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([name])
}

model Permission {
  id        String     @id @default(cuid())
  resource  String // "activities", "customers", "projects", "quotes", "contracts", "payments", "settings", "users"
  action    String // "view", "create", "edit", "delete"
  roles     UserRole[]
  createdAt DateTime   @default(now())

  @@unique([resource, action])
  @@index([resource])
}

model Setting {
  key         String   @id @unique
  value       String // JSON-stringified values
  description String?
  updatedAt   DateTime @updatedAt
}

model Logo {
  id         String   @id @default(cuid())
  url        String // URL to /uploads or CDN
  filename   String
  uploadedAt DateTime @default(now())

  @@index([uploadedAt])
}

model Customer {
  id                String             @id @default(cuid())
  name              String
  shortName         String?
  code              String?            @unique
  language          String             @default("vi")
  taxCode           String?            @unique
  industry          String?
  address           String?
  website           String?
  phone             String?
  email             String?
  source            String?
  notes             String?
  status            CustomerStatus     @default(LEAD)
  isVip             Boolean            @default(false)
  deletedAt         DateTime?
  assignedTo        User               @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId      String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  contacts          Contact[]
  projects          Project[]
  activities        Activity[]
  documents         Document[]
  businessDocuments BusinessDocument[]
  surveys           Survey[]
  emails            EmailMessage[]

  @@index([deletedAt])
  @@index([assignedToId, deletedAt])
  @@index([status, deletedAt])
}

model EmailAccount {
  id         String         @id @default(cuid())
  userId     String         @unique
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  imapHost   String         @default("mail.ahso.vn")
  imapPort   Int            @default(993)
  imapSecure Boolean        @default(true)
  smtpHost   String         @default("mail.ahso.vn")
  smtpPort   Int            @default(587)
  password   String
  signature  String         @default("")
  lastSyncAt DateTime?
  isActive   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  messages   EmailMessage[]
}

model EmailMessage {
  id             String            @id @default(cuid())
  accountId      String
  account        EmailAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  uid            Int
  folder         String
  messageId      String?
  inReplyTo      String?
  fromName       String?
  fromEmail      String
  toAddresses    Json
  ccAddresses    Json              @default("[]")
  bccAddresses   Json              @default("[]")
  subject        String?
  bodyText       String?
  bodyHtml       String?
  snippet        String?
  isRead         Boolean           @default(false)
  isStarred      Boolean           @default(false)
  isDraft        Boolean           @default(false)
  draftId        String?           @unique
  hasAttachments Boolean           @default(false)
  size           Int               @default(0)
  receivedAt     DateTime
  createdAt      DateTime          @default(now())
  attachments    EmailAttachment[]
  customerId     String?
  customer       Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([accountId, uid, folder])
  @@index([accountId, folder, receivedAt(sort: Desc)])
  @@index([customerId])
  @@index([fromEmail])
}

model EmailAttachment {
  id        String       @id @default(cuid())
  messageId String
  message   EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  filePath  String?
  cid       String?
}

enum CustomerStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
}

model Contact {
  id         String    @id @default(cuid())
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean   @default(false)
  notes      String?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
}

model Project {
  id                String             @id @default(cuid())
  code              String             @unique @default(cuid())
  name              String
  description       String?
  status            ProjectStatus      @default(SURVEY)
  priority          Priority           @default(NORMAL)
  estimatedValue    Decimal?           @db.Decimal(15, 0)
  startDate         DateTime?
  expectedEndDate   DateTime?
  notes             String?
  deletedAt         DateTime?
  customer          Customer           @relation(fields: [customerId], references: [id])
  customerId        String
  contact           Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  quotes            Quote[]
  contract          Contract?
  activities        Activity[]
  milestones        Milestone[]
  businessDocuments BusinessDocument[]
  surveys           Survey[]
  handovers         ProjectHandover[]
  stockIssues       StockIssue[]

  @@index([customerId, deletedAt])
  @@index([status, deletedAt])
}

enum ProjectStatus {
  SURVEY
  QUOTING
  NEGOTIATING
  WON
  LOST
  DELIVERING
  COMPLETED
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

model Quote {
  id                String             @id @default(cuid())
  quoteNo           String             @unique
  version           Int                @default(1)
  status            QuoteStatus        @default(DRAFT)
  validUntil        DateTime?
  subtotal          Decimal            @default(0) @db.Decimal(15, 0)
  taxRate           Decimal            @default(10) @db.Decimal(5, 2)
  taxAmount         Decimal            @default(0) @db.Decimal(15, 0)
  total             Decimal            @default(0) @db.Decimal(15, 0)
  terms             String?
  deliveryTerms     String?
  internalNote      String?
  sentAt            DateTime?
  acceptedAt        DateTime?
  project           Project            @relation(fields: [projectId], references: [id])
  projectId         String
  createdBy         User               @relation(fields: [createdById], references: [id])
  createdById       String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  items             QuoteItem[]
  businessDocuments BusinessDocument[]

  @@index([projectId, deletedAt])
  @@index([status, deletedAt])
  @@index([createdById, deletedAt])
}

model QuoteItem {
  id          String    @id @default(cuid())
  order       Int
  name        String
  description String?
  unit        String?
  quantity    Decimal   @db.Decimal(10, 2)
  unitPrice   Decimal   @db.Decimal(15, 0)
  total       Decimal   @db.Decimal(15, 0)
  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  material    Material? @relation(fields: [materialId], references: [id])
  materialId  String?

  @@index([quoteId, order])
  @@index([materialId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Contract {
  id                String             @id @default(cuid())
  contractNo        String             @unique
  signDate          DateTime?
  startDate         DateTime?
  endDate           DateTime?
  value             Decimal            @db.Decimal(15, 0)
  status            ContractStatus     @default(ACTIVE)
  fileUrl           String?
  notes             String?
  project           Project            @relation(fields: [projectId], references: [id])
  projectId         String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  milestones        Milestone[]
  payments          Payment[]
  businessDocuments BusinessDocument[]

  @@index([projectId, deletedAt])
  @@index([status, deletedAt])
}

enum ContractStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
}

model Milestone {
  id            String          @id @default(cuid())
  name          String
  description   String?
  dueDate       DateTime?
  completedAt   DateTime?
  status        MilestoneStatus @default(PENDING)
  paymentAmount Decimal?        @db.Decimal(15, 0)
  notes         String?
  project       Project         @relation(fields: [projectId], references: [id])
  projectId     String
  contract      Contract?       @relation(fields: [contractId], references: [id])
  contractId    String?
  createdAt     DateTime        @default(now())
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
  ACCEPTED
}

model Payment {
  id                String             @id @default(cuid())
  amount            Decimal            @db.Decimal(15, 0)
  paidAt            DateTime
  method            String?
  reference         String?
  notes             String?
  contract          Contract           @relation(fields: [contractId], references: [id])
  contractId        String
  businessDocuments BusinessDocument[]
  createdAt         DateTime           @default(now())
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  title         String
  content       String?
  scheduledAt   DateTime?
  doneAt        DateTime?
  isCompleted   Boolean      @default(false)
  attachmentUrl String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  customerId    String?
  project       Project?     @relation(fields: [projectId], references: [id])
  projectId     String?
  user          User         @relation(fields: [userId], references: [id])
  userId        String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime? // soft delete

  @@index([deletedAt])
}

model Survey {
  id                   String        @id @default(cuid())
  title                String
  surveyedAt           DateTime?
  location             String?
  customerParticipants String?
  objectives           String?
  summary              String?
  nextStep             String?
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId           String
  project              Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId            String?
  createdBy            User          @relation("SurveyCreatedBy", fields: [createdById], references: [id])
  createdById          String
  media                SurveyMedia[]
  notes                SurveyNote[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([projectId, surveyedAt])
  @@index([customerId, surveyedAt])
  @@index([createdById, createdAt])
}

model SurveyMedia {
  id           String          @id @default(cuid())
  survey       Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  surveyId     String
  kind         SurveyMediaKind
  url          String
  filename     String
  mimeType     String
  size         Int
  caption      String?
  area         String?
  isImportant  Boolean         @default(false)
  uploadedBy   User            @relation("SurveyMediaUploadedBy", fields: [uploadedById], references: [id])
  uploadedById String
  createdAt    DateTime        @default(now())

  @@index([surveyId, createdAt])
  @@index([uploadedById, createdAt])
}

model SurveyNote {
  id          String         @id @default(cuid())
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  surveyId    String
  type        SurveyNoteType @default(GENERAL)
  content     String
  isImportant Boolean        @default(false)
  createdBy   User           @relation("SurveyNoteCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([surveyId, createdAt])
  @@index([createdById, createdAt])
}

enum SurveyMediaKind {
  IMAGE
  VIDEO
  FILE
}

enum SurveyNoteType {
  GENERAL
  TECHNICAL_REQUIREMENT
  COMMERCIAL_REQUIREMENT
  SITE_CONSTRAINT
  RISK
  DECISION
  OPEN_QUESTION
}

model BusinessDocument {
  id                  String                 @id @default(cuid())
  type                BusinessDocumentType
  source              BusinessDocumentSource
  status              BusinessDocumentStatus @default(RECEIVED)
  title               String
  documentNo          String?
  documentDate        DateTime?
  fileUrl             String?
  filename            String?
  mimeType            String?
  size                Int?
  notes               String?
  customer            Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId          String?
  project             Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId           String?
  quote               Quote?                 @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  quoteId             String?
  contract            Contract?              @relation(fields: [contractId], references: [id], onDelete: SetNull)
  contractId          String?
  payment             Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  paymentId           String?
  generatedDocument   Document?              @relation(fields: [generatedDocumentId], references: [id], onDelete: SetNull)
  generatedDocumentId String?
  parent              BusinessDocument?      @relation("BusinessDocumentLineage", fields: [parentId], references: [id], onDelete: SetNull)
  parentId            String?
  children            BusinessDocument[]     @relation("BusinessDocumentLineage")
  createdBy           User                   @relation("BusinessDocumentCreatedBy", fields: [createdById], references: [id])
  createdById         String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([projectId, type, createdAt])
  @@index([customerId, createdAt])
  @@index([quoteId])
  @@index([contractId])
  @@index([paymentId])
  @@index([parentId])
  @@index([createdById, createdAt])
}

enum BusinessDocumentType {
  RFQ
  CUSTOMER_PO
  QUOTATION
  SIGNED_QUOTATION
  PROPOSAL
  CONTRACT
  SIGNED_CONTRACT
  CONTRACT_ADDENDUM
  NDA
  DELIVERY_NOTE
  DOC_HANDOVER
  INSTALLATION_REPORT
  ACCEPTANCE_REPORT
  PARTIAL_ACCEPTANCE
  WARRANTY_CERT
  MAINTENANCE_RECORD
  PAYMENT_REQUEST
  PAYMENT_RECEIPT
  INVOICE
  AR_RECONCILIATION
  OTHER
}

enum BusinessDocumentSource {
  GENERATED
  UPLOADED
  RECEIVED
  SIGNED_UPLOAD
}

enum BusinessDocumentStatus {
  DRAFT
  ISSUED
  RECEIVED
  SIGNED
  ACCEPTED
  REJECTED
  SUPERSEDED
  CANCELLED
  ARCHIVED
}

model ProjectHandover {
  id                   String   @id @default(cuid())
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  summary              String?
  customerRequirements String?
  risks                String?
  decisions            String?
  openTasks            String?
  importantDocumentIds String[]
  fromUser             User?    @relation("ProjectHandoverFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  fromUserId           String?
  toUser               User?    @relation("ProjectHandoverToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  toUserId             String?
  createdBy            User     @relation("ProjectHandoverCreatedBy", fields: [createdById], references: [id])
  createdById          String
  createdAt            DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([createdById, createdAt])
}

model Webhook {
  id          String       @id @default(cuid())
  url         String
  events      String[]
  secret      String
  isActive    Boolean      @default(true)
  createdById String?
  createdBy   User?        @relation("WebhookCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  lastFired   DateTime?
  failCount   Int          @default(0)
  logs        WebhookLog[]

  @@index([createdById, createdAt])
  @@index([isActive])
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  response   String?
  statusCode Int?
  firedAt    DateTime @default(now())
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, firedAt])
  @@index([event, firedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  changes    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CustomField {
  id        String             @id @default(cuid())
  resource  String
  name      String
  label     String
  type      String
  options   Json?
  required  Boolean            @default(false)
  order     Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  values    CustomFieldValue[]

  @@unique([resource, name])
  @@index([resource, order])
}

model CustomFieldValue {
  id         String      @id @default(cuid())
  fieldId    String
  resourceId String
  value      String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  field      CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, resourceId])
  @@index([resourceId])
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdById String
  resource    String
  config      Json
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById, createdAt])
  @@index([resource, isShared])
}

model DocumentTemplateVariant {
  id               String                    @id @default(cuid())
  type             DocumentType
  name             String
  status           DocumentTemplateStatus    @default(DRAFT)
  isActive         Boolean                   @default(false)
  layoutJson       Json
  version          Int                       @default(1)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  basedOnVariantId String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  createdBy        User                      @relation("DocumentTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy       User?                     @relation("DocumentTemplateApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  basedOnVariant   DocumentTemplateVariant?  @relation("DocumentTemplateVariantFork", fields: [basedOnVariantId], references: [id], onDelete: SetNull)
  derivedVariants  DocumentTemplateVariant[] @relation("DocumentTemplateVariantFork")

  @@index([type, status, createdAt])
  @@index([type, isActive])
  @@index([createdById, createdAt])
}

enum DocumentTemplateStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ARCHIVED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SURVEY
  DEMO
  NOTE
  FOLLOWUP
}

model Document {
  id                String             @id @default(cuid())
  type              DocumentType
  number            String             @unique
  version           Int                @default(1)
  language          String             @default("vi")
  entityType        String
  entityId          String
  customerId        String?
  pdfPath           String?
  renderedAt        DateTime?
  createdAt         DateTime           @default(now())
  createdById       String
  createdBy         User               @relation(fields: [createdById], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  businessDocuments BusinessDocument[]

  @@index([entityType, entityId])
  @@index([customerId])
  @@index([type, createdAt])
}

enum DocumentType {
  QUOTATION
  PROPOSAL
  SURVEY_REPORT
  CONTRACT
  CONTRACT_ADDENDUM
  NDA
  DELIVERY_NOTE
  DOC_HANDOVER
  INSTALLATION_REPORT
  ACCEPTANCE_REPORT
  PARTIAL_ACCEPTANCE
  WARRANTY_CERT
  MAINTENANCE_RECORD
  PAYMENT_REQUEST
  PAYMENT_RECEIPT
  AR_RECONCILIATION
}

// ============================================================
// INVENTORY & MATERIALS
// ============================================================

enum StockDocStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model Supplier {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  taxCode     String?
  address     String?
  phone       String?
  email       String?
  contactName String?
  notes       String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  materialSuppliers MaterialSupplier[]
  receipts          StockReceipt[]

  @@index([deletedAt])
  @@index([name])
}

model MaterialCategory {
  id        String             @id @default(cuid())
  code      String             @unique
  name      String             @unique
  parentId  String?
  parent    MaterialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  MaterialCategory[] @relation("CategoryTree")
  materials Material[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Material {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  unit        String
  salePrice   Decimal           @default(0) @db.Decimal(15, 0)
  costPrice   Decimal           @default(0) @db.Decimal(15, 0)
  minStock    Decimal?          @db.Decimal(15, 3)
  categoryId  String?
  category    MaterialCategory? @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  isActive    Boolean           @default(true)
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  suppliers          MaterialSupplier[]
  stockBalances      StockBalance[]
  stockReceiptItems  StockReceiptItem[]
  stockIssueItems    StockIssueItem[]
  stockTransferItems StockTransferItem[]
  stockCountItems    StockCountItem[]
  quoteItems         QuoteItem[]

  @@index([deletedAt])
  @@index([code])
  @@index([categoryId])
}

model MaterialSupplier {
  id           String   @id @default(cuid())
  materialId   String
  material     Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  supplierCode String?
  costPrice    Decimal  @default(0) @db.Decimal(15, 0)
  leadTimeDays Int?
  isPreferred  Boolean  @default(false)

  @@unique([materialId, supplierId])
  @@index([supplierId])
}

model Warehouse {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  address   String?
  managerId String?
  manager   User?     @relation("WarehouseManager", fields: [managerId], references: [id])
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stockBalances StockBalance[]
  receipts      StockReceipt[]
  issues        StockIssue[]
  transfersFrom StockTransfer[] @relation("TransferFromWarehouse")
  transfersTo   StockTransfer[] @relation("TransferToWarehouse")
  stockCounts   StockCount[]

  @@index([deletedAt])
}

model StockBalance {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(15, 3)
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, materialId])
  @@index([materialId])
}

model StockReceipt {
  id          String         @id @default(cuid())
  receiptNo   String         @unique
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  date        DateTime
  status      StockDocStatus @default(DRAFT)
  notes       String?
  totalAmount Decimal        @default(0) @db.Decimal(15, 0)
  createdById String
  createdBy   User           @relation("ReceiptCreatedBy", fields: [createdById], references: [id])
  confirmedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items StockReceiptItem[]

  @@index([deletedAt])
  @@index([status])
  @@index([warehouseId])
}

model StockReceiptItem {
  id         String       @id @default(cuid())
  receiptId  String
  receipt    StockReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  materialId String
  material   Material     @relation(fields: [materialId], references: [id])
  quantity   Decimal      @db.Decimal(15, 3)
  unitPrice  Decimal      @db.Decimal(15, 0)
  total      Decimal      @db.Decimal(15, 0)

  @@index([receiptId])
  @@index([materialId])
}

model StockIssue {
  id          String         @id @default(cuid())
  issueNo     String         @unique
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id])
  date        DateTime
  status      StockDocStatus @default(DRAFT)
  reason      String?
  notes       String?
  totalAmount Decimal        @default(0) @db.Decimal(15, 0)
  createdById String
  createdBy   User           @relation("IssueCreatedBy", fields: [createdById], references: [id])
  confirmedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items StockIssueItem[]

  @@index([deletedAt])
  @@index([status])
  @@index([warehouseId])
  @@index([projectId])
}

model StockIssueItem {
  id         String     @id @default(cuid())
  issueId    String
  issue      StockIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  materialId String
  material   Material   @relation(fields: [materialId], references: [id])
  quantity   Decimal    @db.Decimal(15, 3)
  unitPrice  Decimal    @db.Decimal(15, 0)
  total      Decimal    @db.Decimal(15, 0)

  @@index([issueId])
  @@index([materialId])
}

model StockTransfer {
  id              String         @id @default(cuid())
  transferNo      String         @unique
  fromWarehouseId String
  fromWarehouse   Warehouse      @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  date            DateTime
  status          StockDocStatus @default(DRAFT)
  notes           String?
  createdById     String
  createdBy       User           @relation("TransferCreatedBy", fields: [createdById], references: [id])
  confirmedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items StockTransferItem[]

  @@index([deletedAt])
  @@index([status])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  materialId String
  material   Material      @relation(fields: [materialId], references: [id])
  quantity   Decimal       @db.Decimal(15, 3)

  @@index([transferId])
  @@index([materialId])
}

model StockCount {
  id          String         @id @default(cuid())
  countNo     String         @unique
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  date        DateTime
  status      StockDocStatus @default(DRAFT)
  notes       String?
  createdById String
  createdBy   User           @relation("CountCreatedBy", fields: [createdById], references: [id])
  confirmedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items StockCountItem[]

  @@index([deletedAt])
  @@index([status])
}

model StockCountItem {
  id             String     @id @default(cuid())
  countId        String
  count          StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  materialId     String
  material       Material   @relation(fields: [materialId], references: [id])
  systemQuantity Decimal    @db.Decimal(15, 3)
  actualQuantity Decimal    @db.Decimal(15, 3)
  diff           Decimal    @db.Decimal(15, 3)

  @@index([countId])
  @@index([materialId])
}

model AiProviderCredential {
  id            String    @id @default(cuid())
  provider      String    @unique
  authMode      String
  modelOverride String?
  accessToken   String?
  refreshToken  String?
  tokenType     String?
  scopes        String[]
  expiresAt     DateTime?
  status        String    @default("ACTIVE")
  connectedById String?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([provider, status])
}

model AiOAuthState {
  id          String    @id @default(cuid())
  state       String    @unique
  provider    String
  redirectUri String
  createdById String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider, expiresAt])
}

model AiUsageLog {
  id               String   @id @default(cuid())
  provider         String
  model            String
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  feature          String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCost    Decimal? @db.Decimal(12, 6)
  durationMs       Int
  status           String
  errorCode        String?
  createdAt        DateTime @default(now())

  @@index([provider, createdAt])
  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([status, createdAt])
}

model Agent {
  id           String     @id @default(cuid())
  name         String
  description  String?
  systemPrompt String
  provider     String?
  model        String?
  enabledTools String[]
  isActive     Boolean    @default(true)
  createdById  String
  createdBy    User       @relation("AgentCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  runs         AgentRun[]

  @@index([isActive, createdAt])
  @@index([createdById])
}

model AgentRun {
  id         String          @id @default(cuid())
  agentId    String
  agent      Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  status     String
  input      String
  output     String?
  error      String?
  durationMs Int?
  createdAt  DateTime        @default(now())
  messages   AgentMessage[]
  toolCalls  AgentToolCall[]

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AgentMessage {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([runId, createdAt])
}

model AgentToolCall {
  id         String   @id @default(cuid())
  runId      String
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  toolName   String
  inputJson  Json
  outputJson Json?
  status     String
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([runId, createdAt])
  @@index([toolName, createdAt])
}
