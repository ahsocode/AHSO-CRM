{{!-- Phase 10: Acceptance Report Template (Bilingual VI-EN) --}}
<div class="classic-header">
  <div class="classic-header__republic-line">{{t "republic_header"}}</div>
  <div class="classic-header__motto">{{t "independence_motto"}}</div>
  <div class="classic-header__dash">-----------------</div>
  <h1 class="classic-header__title">{{t "document_title_acceptance_report"}}</h1>
  <div class="classic-header__meta">
    <span class="lang-vi">Số:</span><span class="lang-en">No.:</span> BBNT-{{contract.contractNo}}/{{date generatedAt "year"}}
  </div>
</div>

<main class="classic-body">
  <p><strong>
    <span class="lang-vi">{{t "acceptance_statement" date=(date acceptanceDate "long") contractNo=contract.contractNo}}</span>
    <span class="lang-en">Today, on {{date acceptanceDate "short"}}, the parties conduct the User Acceptance Testing (UAT) for the system under Economic Contract No. {{contract.contractNo}}.</span>
  </strong></p>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">
    <span class="lang-vi">{{t "acceptance_sender"}}</span><span class="lang-en">HANDOVER PARTY</span> ({{t "party_b"}})
  </h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th><span class="lang-vi">Tên công ty:</span><span class="lang-en">Company Name:</span></th>
      <td><strong>{{company.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "address"}}:</th>
      <td>{{company.address}}</td>
    </tr>
    <tr>
      <th>{{t "representative"}}:</th>
      <td><span class="lang-vi">Ông/Bà:</span><span class="lang-en">Mr/Ms:</span> <strong>{{company.representative}}</strong> - <span class="lang-vi">Chức vụ:</span><span class="lang-en">Title:</span> {{company.representativeTitle}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">
    <span class="lang-vi">{{t "acceptance_recipient"}}</span><span class="lang-en">ACCEPTING PARTY</span> ({{t "party_a"}})
  </h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th><span class="lang-vi">Tên công ty:</span><span class="lang-en">Company Name:</span></th>
      <td><strong>{{customer.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "address"}}:</th>
      <td>{{customer.address}}</td>
    </tr>
    <tr>
      <th>{{t "representative"}}:</th>
      <td><span class="lang-vi">Ông/Bà:</span><span class="lang-en">Mr/Ms:</span> <strong>{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</strong> - <span class="lang-vi">Chức vụ:</span><span class="lang-en">Title:</span> {{#if primaryContact}}{{primaryContact.title}}{{else}}...................{{/if}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 16pt;">
    <span class="lang-vi">{{t "acceptance_items"}}</span>
    <span class="lang-en">Technical Acceptance Results</span>
  </h3>
  <table border="1" cellpadding="6" cellspacing="0" style="width: 100%; border-collapse: collapse; margin-top: 8pt; border: 1pt solid text;">
    <thead>
      <tr style="background-color: #f3f4f6;">
        <th style="width: 40pt; text-align: center;">STT/<span class="lang-en">No.</span></th>
        <th>
          <span class="lang-vi">{{t "test_name"}}</span>
          <br><span class="lang-en">Item / Test Case</span>
        </th>
        <th style="width: 100pt; text-align: center;">
          <span class="lang-vi">{{t "test_status"}}</span>
          <br><span class="lang-en">Result</span>
        </th>
        <th style="width: 120pt; text-align: left;">
          <span class="lang-vi">{{t "test_note"}}</span>
          <br><span class="lang-en">Note</span>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each testResults}}
      <tr>
        <td style="text-align: center;">{{add @index 1}}</td>
        <td><strong>{{this.name}}</strong></td>
        <td style="text-align: center;">{{this.status}}</td>
        <td>{{this.note}}</td>
      </tr>
      {{/each}}
      {{#if (not testResults.length)}}
      <tr>
        <td colspan="4" style="text-align: center; color: #6b7280;">
          <span class="lang-vi">(Chi tiết nghiệm thu trống)</span>
          <span class="lang-en">(Empty testing results)</span>
        </td>
      </tr>
      {{/if}}
    </tbody>
  </table>

  <p style="margin-top: 16pt;">
    <span class="lang-vi">{{t "acceptance_confirmation"}}</span>
    <span class="lang-en">The system fully meets the technical and business requirements in accordance with the Contract appendix. Both parties agree to accept and put it into official use. This minute is made into 02 original copies with equal legal validity, each party keeps 01 copy.</span>
  </p>

  <div class="avoid-break" style="margin-top: 40pt;">
    <div class="signature-grid classic-signature">
      <div class="signature-col text-center">
        <div class="signature-block__label">
          <strong><span class="lang-vi">ĐẠI DIỆN</span><span class="lang-en">REPRESENTATIVE OF</span> {{t "acceptance_recipient"}}</strong>
        </div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</div>
      </div>
      <div class="signature-col text-center">
        <div class="signature-block__label">
          <strong><span class="lang-vi">ĐẠI DIỆN</span><span class="lang-en">REPRESENTATIVE OF</span> {{t "acceptance_sender"}}</strong>
        </div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{company.representative}}</div>
      </div>
    </div>
  </div>
</main>

{{> footer-page}}
