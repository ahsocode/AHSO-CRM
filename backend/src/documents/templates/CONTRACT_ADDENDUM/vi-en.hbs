{{!-- Phase 5: Contract Addendum Template (Bilingual VI-EN) --}}
<div class="classic-header">
  <div class="classic-header__republic-line">{{t "republic_header"}}</div>
  <div class="classic-header__motto">{{t "independence_motto"}}</div>
  <div class="classic-header__dash">-----------------</div>
  <h1 class="classic-header__title">{{t "document_title_contract_addendum"}}</h1>
  <div class="classic-header__meta">
    <span class="lang-vi">Số:</span><span class="lang-en">No.:</span> {{contract.contractNo}}/PL-{{date generatedAt "year"}}
  </div>
</div>

<main class="classic-body">
  <p style="text-indent: 0;"><strong>
    <span class="lang-vi">{{t "addendum_statement" contractNo=contract.contractNo date=(date contract.createdAt "short")}}</span>
    <span class="lang-en">Both parties agree to make and sign this Contract Addendum attached to the Economic Contract No. {{contract.contractNo}} signed on {{date contract.createdAt "short"}}. This Addendum is an inseparable part of the Contract.</span>
  </strong></p>
  
  <p><strong><span class="lang-vi">{{t "agreement_statement" date=(date generatedAt "long") location=company.address}}</span><span class="lang-en">Today, on {{date generatedAt "short"}}, at {{company.address}}, we are:</span></strong></p>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">{{t "party_a"}}</h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th><span class="lang-vi">Tên công ty:</span><span class="lang-en">Company Name:</span></th>
      <td><strong>{{customer.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "address"}}:</th>
      <td>{{customer.address}}</td>
    </tr>
    <tr>
      <th>{{t "tax_code"}}:</th>
      <td>{{customer.taxCode}}</td>
    </tr>
    <tr>
      <th>{{t "representative"}}:</th>
      <td><span class="lang-vi">Ông/Bà:</span><span class="lang-en">Mr/Ms:</span> <strong>{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</strong> - <span class="lang-vi">Chức vụ:</span><span class="lang-en">Title:</span> {{#if primaryContact}}{{primaryContact.title}}{{else}}...................{{/if}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">{{t "party_b"}}</h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th><span class="lang-vi">Tên công ty:</span><span class="lang-en">Company Name:</span></th>
      <td><strong>{{company.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "address"}}:</th>
      <td>{{company.address}}</td>
    </tr>
    <tr>
      <th>{{t "tax_code"}}:</th>
      <td>{{company.taxCode}}</td>
    </tr>
    <tr>
      <th>{{t "representative"}}:</th>
      <td><span class="lang-vi">Ông/Bà:</span><span class="lang-en">Mr/Ms:</span> <strong>{{company.representative}}</strong> - <span class="lang-vi">Chức vụ:</span><span class="lang-en">Title:</span> {{company.representativeTitle}}</td>
    </tr>
  </table>

  <div class="classic-article" style="margin-top: 16pt;">
    <div class="classic-article__heading">{{t "article_change_content"}}</div>
    <div class="classic-article__clause">
      <span class="lang-vi">Các bên thống nhất sửa đổi, bổ sung nội dung Hợp đồng Kinh tế như sau:</span>
      <span class="lang-en">The parties agree to amend and supplement the contents of the Economic Contract as follows:</span>
      <ul>
        {{#each modifications}}
        <li>{{this.content}}</li>
        {{/each}}
      </ul>
    </div>
  </div>

  <div class="classic-article">
    <div class="classic-article__heading">{{t "article_general_terms"}}</div>
    <div class="classic-article__clause">
      <p>{{t "general_terms_content"}}</p>
      <p>{{t "original_copies_statement"}}</p>
    </div>
  </div>

  <div class="avoid-break" style="margin-top: 40pt;">
    <div class="signature-grid classic-signature">
      <div class="signature-col text-center">
        <div class="signature-block__label"><strong><span class="lang-vi">ĐẠI DIỆN</span><span class="lang-en">REPRESENTATIVE OF</span> {{t "party_a"}}</strong></div>
        <div class="signature-block__line"></div>
        <div class="classic-stamp"><span class="lang-vi">ĐÓNG DẤU</span><span class="lang-en">STAMP</span></div>
        <div style="font-weight: bold;">{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</div>
      </div>
      <div class="signature-col text-center">
        <div class="signature-block__label"><strong><span class="lang-vi">ĐẠI DIỆN</span><span class="lang-en">REPRESENTATIVE OF</span> {{t "party_b"}}</strong></div>
        <div class="signature-block__line"></div>
        <div class="classic-stamp"><span class="lang-vi">ĐÓNG DẤU</span><span class="lang-en">STAMP</span></div>
        <div style="font-weight: bold;">{{company.representative}}</div>
      </div>
    </div>
  </div>
</main>

{{> footer-page}}
