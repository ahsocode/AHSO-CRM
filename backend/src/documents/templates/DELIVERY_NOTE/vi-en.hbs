{{!-- Phase 7: Delivery Note Template (Bilingual VI-EN) --}}
<div class="classic-header">
  <div class="classic-header__republic-line">{{t "republic_header"}}</div>
  <div class="classic-header__motto">{{t "independence_motto"}}</div>
  <div class="classic-header__dash">-----------------</div>
  <h1 class="classic-header__title">{{t "document_title_delivery"}}</h1>
  <div class="classic-header__meta">
    <span class="lang-vi">Số:</span><span class="lang-en">No.:</span> BBGH-{{contract.contractNo}}/{{date generatedAt "year"}}
  </div>
</div>

<main class="classic-body">
  <p><strong>
    <span class="lang-vi">{{t "delivery_statement" date=(date deliveryDate "long") contractNo=contract.contractNo}}</span>
    <span class="lang-en">Today, on {{date deliveryDate "short"}}, the parties hand over goods/documents in accordance with Economic Contract No. {{contract.contractNo}}.</span>
  </strong></p>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">
    <span class="lang-vi">{{t "delivery_sender"}}</span><span class="lang-en">DELIVERING PARTY</span> ({{t "party_b"}})
  </h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th><span class="lang-vi">Tên công ty:</span><span class="lang-en">Company Name:</span></th>
      <td><strong>{{company.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "address"}}:</th>
      <td>{{company.address}}</td>
    </tr>
    <tr>
      <th><span class="lang-vi">{{t "deliverer"}}:</span><span class="lang-en">Deliverer:</span></th>
      <td><span class="lang-vi">Ông/Bà:</span><span class="lang-en">Mr/Ms:</span> <strong>{{company.representative}}</strong> - <span class="lang-vi">Chức vụ:</span><span class="lang-en">Title:</span> {{company.representativeTitle}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">
    <span class="lang-vi">{{t "delivery_recipient"}}</span><span class="lang-en">RECEIVING PARTY</span> ({{t "party_a"}})
  </h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th><span class="lang-vi">Tên công ty:</span><span class="lang-en">Company Name:</span></th>
      <td><strong>{{customer.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "delivery_location"}}:</th>
      <td>{{customer.address}}</td>
    </tr>
    <tr>
      <th>{{t "representative"}}:</th>
      <td><span class="lang-vi">Ông/Bà:</span><span class="lang-en">Mr/Ms:</span> <strong>{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</strong> - <span class="lang-vi">Chức vụ:</span><span class="lang-en">Title:</span> {{#if primaryContact}}{{primaryContact.title}}{{else}}...................{{/if}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 16pt;">
    <span class="lang-vi">{{t "items_delivered"}}</span>
    <span class="lang-en">Details of Delivered Items</span>
  </h3>
  <table border="1" cellpadding="6" cellspacing="0" style="width: 100%; border-collapse: collapse; margin-top: 8pt; border: 1pt solid text;">
    <thead>
      <tr style="background-color: #f3f4f6;">
        <th style="width: 40pt; text-align: center;">STT/<span class="lang-en">No.</span></th>
        <th>
          <span class="lang-vi">{{t "description"}}</span>
          <br><span class="lang-en">Description</span>
        </th>
        <th style="width: 60pt; text-align: center;">
          <span class="lang-vi">{{t "unit"}}</span>
          <br><span class="lang-en">Unit</span>
        </th>
        <th style="width: 80pt; text-align: right;">
          <span class="lang-vi">{{t "qty"}}</span>
          <br><span class="lang-en">Qty</span>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each deliveredItems}}
      <tr>
        <td style="text-align: center;">{{add @index 1}}</td>
        <td>
          <strong>{{this.name}}</strong>
          {{#if this.description}}<div style="font-size: 10pt; color: #4b5563;">{{this.description}}</div>{{/if}}
        </td>
        <td style="text-align: center;">{{this.unit}}</td>
        <td style="text-align: right;">{{this.quantity}}</td>
      </tr>
      {{/each}}
      {{#if (not deliveredItems.length)}}
      <tr>
        <td colspan="4" style="text-align: center; color: #6b7280;">
          <span class="lang-vi">(Hạng mục giao nhận được tính theo Phụ lục Hợp đồng)</span>
          <span class="lang-en">(Items delivered are calculated according to the Contract Addendum)</span>
        </td>
      </tr>
      {{/if}}
    </tbody>
  </table>

  <h3 style="margin-top: 16pt;">
    <span class="lang-vi">{{t "quality_status"}}</span>
    <span class="lang-en">Quality Status</span>
  </h3>
  <p>
    <span class="lang-vi">{{t "quality_status_desc"}}</span>
    <span class="lang-en">100% brand new, strictly conforming to the specifications, categories and technical standards defined in the Contract.</span>
  </p>

  <p style="margin-top: 12pt;">
    <span class="lang-vi">Biên bản được lập thành 02 bản, mỗi bên giữ 01 bản có giá trị pháp lý như nhau. Hai bên đã kiểm tra kỹ và đồng ý ký tên xác nhận dưới đây.</span>
    <span class="lang-en">This minute is made into 02 original copies with equal legal validity, each party keeps 01 copy. Both parties have carefully checked and agreed to sign below for confirmation.</span>
  </p>

  <div class="avoid-break" style="margin-top: 30pt;">
    <div class="signature-grid classic-signature">
      <div class="signature-col text-center">
        <div class="signature-block__label">
          <strong><span class="lang-vi">ĐẠI DIỆN</span><span class="lang-en">REPRESENTATIVE OF</span> {{t "delivery_recipient"}}</strong>
        </div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</div>
      </div>
      <div class="signature-col text-center">
        <div class="signature-block__label">
          <strong><span class="lang-vi">ĐẠI DIỆN</span><span class="lang-en">REPRESENTATIVE OF</span> {{t "delivery_sender"}}</strong>
        </div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{company.representative}}</div>
      </div>
    </div>
  </div>
</main>

{{> footer-page}}
