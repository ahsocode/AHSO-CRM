{{!-- Phase 13: Maintenance Record Template (Vietnamese) --}}
<div class="classic-header">
  <div class="classic-header__republic-line">{{t "republic_header"}}</div>
  <div class="classic-header__motto">{{t "independence_motto"}}</div>
  <div class="classic-header__dash">-----------------</div>
  <h1 class="classic-header__title">{{t "document_title_maintenance_record"}}</h1>
  <div class="classic-header__meta">{{t "doc_number"}}: BBBT-{{contract.contractNo}}/{{date generatedAt "year"}}</div>
</div>

<main class="classic-body">
  <p><strong>{{t "maintenance_statement" date=(date maintenanceDate "long") contractNo=contract.contractNo}}</strong></p>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">{{t "delivery_sender"}} ({{t "party_b"}})</h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th>Tên công ty:</th>
      <td><strong>{{company.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "technician"}}:</th>
      <td>Ông/Bà: <strong>{{technician}}</strong></td>
    </tr>
  </table>

  <h3 style="margin-top: 12pt; text-transform: uppercase;">{{t "delivery_recipient"}} ({{t "party_a"}})</h3>
  <table class="classic-parties" width="100%">
    <tr>
      <th>Tên công ty:</th>
      <td><strong>{{customer.name}}</strong></td>
    </tr>
    <tr>
      <th>{{t "address"}}:</th>
      <td>{{customer.address}}</td>
    </tr>
    <tr>
      <th>{{t "representative"}}:</th>
      <td>Ông/Bà: <strong>{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</strong> - Chức vụ: {{#if primaryContact}}{{primaryContact.title}}{{else}}...................{{/if}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 16pt;">{{t "maintenance_items"}}</h3>
  <table border="1" cellpadding="6" cellspacing="0" style="width: 100%; border-collapse: collapse; margin-top: 8pt; border: 1pt solid text;">
    <thead>
      <tr style="background-color: #f3f4f6;">
        <th style="width: 40pt; text-align: center;">STT</th>
        <th>{{t "maintenance_name"}}</th>
        <th style="width: 120pt; text-align: center;">{{t "maintenance_status"}}</th>
        <th style="width: 120pt; text-align: left;">{{t "maintenance_note"}}</th>
      </tr>
    </thead>
    <tbody>
      {{#each issues}}
      <tr>
        <td style="text-align: center;">{{add @index 1}}</td>
        <td><strong>{{this.name}}</strong></td>
        <td style="text-align: center;">{{this.status}}</td>
        <td>{{this.note}}</td>
      </tr>
      {{/each}}
      {{#if (not issues.length)}}
      <tr>
        <td colspan="4" style="text-align: center; color: #6b7280;">(Chi tiết bảo trì trống)</td>
      </tr>
      {{/if}}
    </tbody>
  </table>

  <p style="margin-top: 16pt;">{{t "maintenance_confirmation"}}</p>

  <div class="avoid-break" style="margin-top: 30pt;">
    <div class="signature-grid classic-signature">
      <div class="signature-col text-center">
        <div class="signature-block__label"><strong>XÁC NHẬN TỪ {{t "delivery_recipient"}}</strong></div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{#if primaryContact}}{{primaryContact.name}}{{else}}.......................................{{/if}}</div>
      </div>
      <div class="signature-col text-center">
        <div class="signature-block__label"><strong>{{t "technician"}}</strong></div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{technician}}</div>
      </div>
    </div>
  </div>
</main>

{{> footer-page}}
