{{!-- Phase 15: Payment Receipt Template (Bilingual VI-EN) --}}
<div class="classic-header">
  <div class="classic-header__republic-line">{{t "republic_header"}}</div>
  <div class="classic-header__motto">{{t "independence_motto"}}</div>
  <div class="classic-header__dash">-----------------</div>
  <h1 class="classic-header__title">{{t "document_title_payment_receipt"}}</h1>
  <div class="classic-header__meta">
    <span class="lang-vi">Số:</span><span class="lang-en">No.:</span>
    PT-{{contract.contractNo}}/{{date generatedAt "year"}}
  </div>
</div>

<main class="classic-body">
  <table class="classic-parties" width="100%" style="margin-top: 16pt;">
    <tr>
      <th style="width: 35%;">
        <span class="lang-vi">{{t "receipt_payer"}}:</span>
        <span class="lang-en">Payer:</span>
      </th>
      <td><strong>{{payerName}}</strong></td>
    </tr>
    <tr>
      <th>
        <span class="lang-vi">Đại diện cho:</span>
        <span class="lang-en">On behalf of:</span>
      </th>
      <td><strong>{{customer.name}}</strong></td>
    </tr>
    <tr>
      <th>
        <span class="lang-vi">{{t "receipt_reason"}}:</span>
        <span class="lang-en">Purpose:</span>
      </th>
      <td>{{receiptReason}}</td>
    </tr>
    <tr>
      <th>
        <span class="lang-vi">{{t "payment_method"}}:</span>
        <span class="lang-en">Payment Method:</span>
      </th>
      <td>{{paymentMethod}}</td>
    </tr>
    <tr>
      <th>
        <span style="color: #b91c1c; font-size: 13pt;">
          <span class="lang-vi">{{t "receipt_amount"}}:</span>
          <span class="lang-en">Amount Received:</span>
        </span>
      </th>
      <td>
        <span style="font-size: 16pt; font-weight: 800; color: #b91c1c;">{{currency receiptAmount}}</span>
      </td>
    </tr>
    <tr>
      <th>
        <span class="lang-vi">{{t "payment_amount_words"}}:</span>
        <span class="lang-en">In words:</span>
      </th>
      <td><i>{{currency receiptAmount "words"}} đồng.</i></td>
    </tr>
    <tr>
      <th>
        <span class="lang-vi">Ngày thu:</span>
        <span class="lang-en">Date:</span>
      </th>
      <td>{{date receiptDate "long"}}</td>
    </tr>
  </table>

  <p style="margin-top: 20pt; font-style: italic; color: #374151;">
    <span class="lang-vi">{{t "receipt_confirmation"}}</span>
    <span class="lang-en">The above amount has been received in full. This receipt is made in 02 copies, one for the collector and one for the payer.</span>
  </p>

  <div class="avoid-break" style="margin-top: 40pt;">
    <div class="signature-grid classic-signature">
      <div class="signature-col text-center">
        <div class="signature-block__label">
          <strong>
            <span class="lang-vi">{{t "receipt_payer"}}</span>
            <span class="lang-en">PAYER</span>
          </strong>
        </div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{payerName}}</div>
      </div>
      <div class="signature-col text-center">
        <div class="signature-block__label">
          <strong>
            <span class="lang-vi">{{t "receipt_cashier"}}</span>
            <span class="lang-en">CASHIER</span>
          </strong>
        </div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">{{cashier}}</div>
      </div>
    </div>
  </div>
</main>

{{> footer-page}}
