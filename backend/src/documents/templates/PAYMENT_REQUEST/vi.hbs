{{!-- Phase 14: Payment Request Template (Vietnamese) --}}
<div class="classic-header">
  <div class="classic-header__republic-line">{{t "republic_header"}}</div>
  <div class="classic-header__motto">{{t "independence_motto"}}</div>
  <div class="classic-header__dash">-----------------</div>
  <h1 class="classic-header__title">{{t "document_title_payment_request"}}</h1>
  <div class="classic-header__meta">{{t "doc_number"}}: DNTT-{{contract.contractNo}}/{{date generatedAt "year"}}</div>
</div>

<main class="classic-body">
  <div style="margin-bottom: 20pt;">
    <p><strong>Kính gửi (To):</strong> <span style="font-size: 14pt; font-weight: bold; text-transform: uppercase;">CÔNG TY {{customer.name}}</span></p>
  </div>

  <p>{{t "payment_request_content"}}</p>

  <table class="classic-parties" width="100%" style="margin-top: 12pt;">
    <tr>
      <th>Hợp đồng/Dự án:</th>
      <td><strong>{{contract.contractNo}}</strong> - {{project.name}}</td>
    </tr>
    <tr>
      <th>{{t "payment_reason"}}:</th>
      <td>{{paymentReason}}</td>
    </tr>
    <tr>
      <th><span style="color: #b91c1c;">{{t "payment_amount"}}:</span></th>
      <td><span style="font-size: 14pt; color: #b91c1c; font-weight: bold;">{{currency paymentAmount}}</span></td>
    </tr>
    <tr>
      <th><span style="color: #4b5563;">{{t "payment_amount_words"}}:</span></th>
      <td><i style="color: #4b5563;">{{currency paymentAmount "words"}} đồng.</i></td>
    </tr>
    <tr>
      <th>{{t "payment_deadline"}}:</th>
      <td>{{date requestDate "long"}}</td>
    </tr>
  </table>

  <h3 style="margin-top: 20pt; border-bottom: 1pt solid #ccc; padding-bottom: 4pt;">{{t "banking_info"}}</h3>
  <table class="classic-parties" width="100%" style="margin-top: 8pt;">
    <tr>
      <th>{{t "bank_account_name"}}:</th>
      <td><strong>{{bankAccountName}}</strong></td>
    </tr>
    <tr>
      <th>{{t "bank_account_no"}}:</th>
      <td><strong>{{bankAccountNo}}</strong></td>
    </tr>
    <tr>
      <th>{{t "bank_name"}}:</th>
      <td>{{bankName}}</td>
    </tr>
  </table>

  <div class="avoid-break" style="margin-top: 50pt;">
    <div class="signature-grid classic-signature">
      <div class="signature-col text-center">
        <div class="signature-block__label"><strong>{{t "payment_creator"}}</strong></div>
        <div class="signature-block__line"></div>
        <div style="font-weight: bold;">(Ký, ghi rõ họ tên)</div>
      </div>
      <div class="signature-col text-center">
        <div class="signature-block__label"><strong>{{t "payment_approver"}}</strong></div>
        <div style="height: 100pt;">
          <div class="classic-stamp" style="margin-top: -10pt;">KẾ TOÁN TRƯỞNG / GIÁM ĐỐC</div>
        </div>
        <div style="font-weight: bold;">{{company.name}}</div>
      </div>
    </div>
  </div>
</main>

{{> footer-page}}
