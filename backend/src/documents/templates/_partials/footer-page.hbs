{{!-- Running footer with page number + tiny brand line.
       WeasyPrint handles page counters through CSS paged media, so this
       partial is kept as a document-tail fallback for template variants. --}}
<footer class="page-footer">
  <div class="page-footer__brand">{{company.name}}{{#if company.website}} · {{company.website}}{{/if}}</div>
  <div class="page-footer__meta">
    <span class="page-footer__doc">{{#if docNumber}}{{docNumber}}{{/if}}</span>
    <span class="page-footer__generated">{{t "page"}}: <span class="pageNumber"></span></span>
  </div>
</footer>
