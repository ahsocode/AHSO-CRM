<!doctype html>
<html lang="vi">
  <body style="font-family: Arial, sans-serif; color: #1f2937; line-height: 1.6;">
    <p>Kính gửi {{recipientName}},</p>
    <p>{{company.name}} xin gửi đến Quý khách báo giá <strong>{{quoteNo}}</strong> cho dự án <strong>{{projectName}}</strong>.</p>
    <p>
      Giá trị báo giá: <strong>{{quoteTotal}}</strong><br />
